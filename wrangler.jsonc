{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "baoaowebsite",
    "compatibility_date": "2026-05-16",
    "observability": {
      "enabled": true
    },
    "assets": {
      "directory": ".",
      "exclude": [".git/**/*", "node_modules/**/*"]
    },
    "compatibility_flags": ["nodejs_compat"]
  }